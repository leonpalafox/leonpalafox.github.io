---
// Placeholder thumbnails for Selected work, in the monochrome style of the
// mockup. Swap for real imagery by replacing this component's usage with <img>.
interface Props {
  variant: 'dots' | 'chart' | 'arch';
}
const { variant } = Astro.props;

const ringDots: { x: number; y: number; r: number }[] = [];
if (variant === 'dots') {
  for (let ring = 1; ring <= 5; ring++) {
    const n = ring * 8;
    for (let i = 0; i < n; i++) {
      const a = (i / n) * Math.PI * 2;
      ringDots.push({ x: 60 + ring * 9 * Math.cos(a), y: 45 + ring * 9 * Math.sin(a), r: 1.1 });
    }
  }
}

const chartPts = [8, 62, 26, 48, 44, 52, 62, 34, 80, 38, 98, 20, 112, 26];
let chartPath = '';
for (let i = 0; i < chartPts.length; i += 2) {
  chartPath += `${i === 0 ? 'M' : 'L'} ${chartPts[i]} ${chartPts[i + 1]} `;
}
---

<svg viewBox="0 0 120 90" aria-hidden="true" class="h-full w-full">
  <rect width="120" height="90" fill="var(--color-ink)"></rect>
  {variant === 'dots' && ringDots.map((d) => <circle cx={d.x.toFixed(1)} cy={d.y.toFixed(1)} r={d.r} fill="var(--color-sheet)" fill-opacity="0.85" />)}
  {
    variant === 'chart' && (
      <>
        <path d={chartPath} fill="none" stroke="var(--color-sheet)" stroke-width="1.25" />
        {Array.from({ length: 7 }, (_, i) => (
          <circle cx={chartPts[i * 2]} cy={chartPts[i * 2 + 1]} r="2.2" fill="var(--color-sheet)" />
        ))}
      </>
    )
  }
  {
    variant === 'arch' && (
      <>
        <path d="M 120 90 L 120 6 Q 46 14 30 90 Z" fill="var(--color-sheet)" fill-opacity="0.92" />
        <path d="M 120 6 Q 46 14 30 90" fill="none" stroke="var(--color-ink)" stroke-width="1" />
      </>
    )
  }
</svg>
