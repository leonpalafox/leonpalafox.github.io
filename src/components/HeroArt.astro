---
// Recreates the hero illustration from assets/personal_identity.png:
// a vermillion sun inside a hairline orbit ring, over a halftone wave.
// All dots are generated deterministically at build time.

function mulberry32(seed: number) {
  let a = seed;
  return () => {
    a |= 0;
    a = (a + 0x6d2b79f5) | 0;
    let t = Math.imul(a ^ (a >>> 15), 1 | a);
    t = (t + Math.imul(t ^ (t >>> 7), 61 | t)) ^ t;
    return ((t ^ (t >>> 14)) >>> 0) / 4294967296;
  };
}
const rand = mulberry32(20260720);

const waveY = (x: number) => 402 + 30 * Math.sin(x / 70) + 14 * Math.sin(x / 33 + 1.7);

// Filled wave body
let wavePath = 'M 60 620 L 60 ' + waveY(60).toFixed(1);
for (let x = 60; x <= 580; x += 8) {
  wavePath += ` L ${x} ${waveY(x).toFixed(1)}`;
}
wavePath += ' L 580 620 Z';

// Halftone dots dissolving upward from the wave crest
type Dot = { x: number; y: number; r: number; o: number; c: 'ink' | 'sheet' };
const dots: Dot[] = [];
for (let row = 1; row <= 10; row++) {
  for (let x = 62; x <= 578; x += 9) {
    if (rand() > 0.78 - row * 0.045) continue;
    dots.push({
      x: x + (rand() - 0.5) * 4,
      y: waveY(x) - row * 6.5 + (rand() - 0.5) * 3,
      r: 1 + rand() * 0.9,
      o: Math.max(0.12, 0.95 - row * 0.09),
      c: 'ink',
    });
  }
}
// Light dots inside the dark mass, hinting at halftone print
for (let row = 1; row <= 5; row++) {
  for (let x = 62; x <= 578; x += 11) {
    if (rand() > 0.4) continue;
    dots.push({
      x: x + (rand() - 0.5) * 4,
      y: waveY(x) + row * 7 + (rand() - 0.5) * 3,
      r: 0.9 + rand() * 0.7,
      o: Math.max(0.06, 0.5 - row * 0.09),
      c: 'sheet',
    });
  }
}

// Ordered dot-grid patch to the left of the sun
const grid: { x: number; y: number }[] = [];
for (let gx = 128; gx <= 224; gx += 12) {
  for (let gy = 236; gy <= 332; gy += 12) {
    grid.push({ x: gx, y: gy });
  }
}

// Red accent dot on the orbit ring (upper right)
const ringAngle = (-52 * Math.PI) / 180;
const ringDot = { x: 320 + 300 * Math.cos(ringAngle), y: 320 + 300 * Math.sin(ringAngle) };
---

<svg
  viewBox="0 0 640 640"
  role="img"
  aria-label="A red rising sun over a halftone wave of dots, inside a thin orbit ring"
  class="h-auto w-full"
>
  <defs>
    <clipPath id="hero-disc">
      <circle cx="320" cy="320" r="240"></circle>
    </clipPath>
  </defs>

  <!-- orbit ring -->
  <circle cx="320" cy="320" r="300" fill="none" stroke="var(--color-ink)" stroke-opacity="0.35" stroke-width="0.75"></circle>
  <circle cx={ringDot.x.toFixed(1)} cy={ringDot.y.toFixed(1)} r="5" fill="var(--color-signal)"></circle>

  <!-- stray plus marks -->
  {
    [
      [26, 248],
      [72, 476],
      [612, 306],
    ].map(([px, py]) => (
      <path
        d={`M ${px - 6} ${py} H ${px + 6} M ${px} ${py - 6} V ${py + 6}`}
        stroke="var(--color-ink)"
        stroke-opacity="0.45"
        stroke-width="1"
      />
    ))
  }

  <g clip-path="url(#hero-disc)">
    <!-- sun -->
    <circle cx="330" cy="252" r="118" fill="var(--color-signal)"></circle>

    <!-- ordered grid, partially eclipsed -->
    {grid.map((g) => <circle cx={g.x} cy={g.y} r="1.4" fill="var(--color-ink)" fill-opacity="0.4" />)}

    <!-- wave -->
    <path d={wavePath} fill="var(--color-ink)"></path>
    {
      dots.map((d) => (
        <circle
          cx={d.x.toFixed(1)}
          cy={d.y.toFixed(1)}
          r={d.r.toFixed(2)}
          fill={d.c === 'ink' ? 'var(--color-ink)' : 'var(--color-sheet)'}
          fill-opacity={d.o.toFixed(2)}
        />
      ))
    }
  </g>
</svg>
