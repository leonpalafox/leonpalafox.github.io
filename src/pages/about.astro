---
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';

const timeline = [
  { from: '2025.07', to: 'Present', role: 'AI Innovation Lab Director', org: 'GBM', current: true },
  { from: '2024.05', to: '2025.07', role: 'AI Innovation Lab Director', org: 'Novartis' },
  { from: '2022.10', to: '2024.05', role: 'AI Head', org: 'Algorithia (Grupo Salinas)' },
  { from: '2021.07', to: '2022.10', role: 'Machine Learning Director', org: 'Banorte Financial Group' },
  { from: '2018.05', to: '2020.06', role: 'ML & Data Science Professor', org: 'Universidad Panamericana' },
  { from: '2017.03', to: '2018.05', role: 'Senior Data Science Consultant', org: 'Rich IT' },
  { from: '2015.03', to: '2017.03', role: 'Staff Scientist', org: 'University of Arizona' },
  { from: '2014.04', to: '2015.03', role: 'Postdoctoral Fellow', org: 'University of Arizona' },
  { from: '2013.02', to: '2014.04', role: 'Postdoctoral Fellow', org: 'UCLA School of Medicine' },
  { from: '2012.08', to: '2012.09', role: 'Research Intern', org: 'National Institute of Informatics' },
  { from: '2010.03', to: '2013.03', role: 'PhD, Machine Learning', org: 'The University of Tokyo' },
  { from: '2008.04', to: '2010.03', role: "Master's, Information Technologies", org: 'The University of Tokyo' },
  { from: '2007.04', to: '2013.03', role: 'Monbukagakusho (MEXT) Scholarship Fellow', org: 'Government of Japan' },
  { from: '2000.09', to: '2005.04', role: "Bachelor's, Engineering (Magna Cum Laude)", org: 'UNAM' },
];
---

<Base
  title="About — León Palafox"
  description="Director of the AI Innovation Lab at GBM, PhD from the University of Tokyo, lecturer at Universidad Panamericana, and columnist at El Financiero."
>
  <!-- Collage hero: recreates assets/hero_anout.png as a live composition -->
  <section class="relative overflow-hidden border-b border-hairline bg-[#f4ebd7]">
    <!-- Collage canvas (lg+): the artwork is the section background -->
    <img
      src="/images/hero_1.png"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 hidden h-full w-full object-cover object-right-top lg:block"
      loading="eager"
    />
    <!-- Paper veil: guarantees a quiet zone for type at any width -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 hidden bg-[linear-gradient(103deg,#f4ebd7_30%,rgba(244,235,215,0.9)_48%,rgba(244,235,215,0.55)_60%,transparent_76%)] lg:block"
    >
    </div>
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-x-0 bottom-0 hidden h-56 bg-[linear-gradient(to_top,rgba(244,235,215,0.8)_10%,rgba(244,235,215,0.35)_55%,transparent_100%)] lg:block"
    >
    </div>

    <!-- Banner crop of the collage (below lg) -->
    <img
      src="/images/hero_1.png"
      alt="Paper collage of neural networks, market charts, books, and Mexico City architecture"
      class="h-56 w-full object-cover object-right sm:h-72 lg:hidden"
      loading="eager"
    />

    <!-- Drafting-sketch decorations -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 hidden lg:block">
      <div
        class="absolute left-10 top-[46%] h-16 w-20 opacity-45"
        style="background-image: radial-gradient(var(--color-ink) 1px, transparent 1px); background-size: 9px 9px;"
      >
      </div>
      <div class="absolute -bottom-16 -left-12 size-44 rounded-full border border-ink/25"></div>
      <div class="absolute bottom-24 left-16 size-14 rounded-full border border-ink/20"></div>
      <svg class="absolute left-[46%] top-16 size-4 opacity-40" viewBox="0 0 16 16">
        <path d="M8 0 V16 M0 8 H16" stroke="var(--color-ink)" stroke-width="1"></path>
      </svg>
    </div>

    <div class="relative flex flex-col px-6 py-12 sm:px-10 lg:min-h-[660px] lg:justify-between lg:px-14 lg:py-16">
      <header>
        <p class="micro-label flex items-center gap-3 text-signal">
          <span>About</span>
          <span lang="ja" class="text-muted tracking-[0.2em]">略歴</span>
        </p>
        <h1 class="mt-5 text-4xl font-semibold leading-[1.02] tracking-[-0.02em] sm:text-5xl">Hi, I'm León.</h1>
        <span aria-hidden="true" class="mt-6 block h-[3px] w-14 bg-signal"></span>
      </header>

      <div class="mt-12 flex flex-col gap-10 sm:flex-row sm:items-end lg:mt-0 lg:gap-14">
        <!-- Portrait in a drafting frame -->
        <figure class="relative w-44 shrink-0 sm:w-52">
          <span aria-hidden="true" class="absolute -left-6 -top-3 h-px w-[calc(100%+3rem)] bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -top-6 -left-3 h-[calc(100%+3rem)] w-px bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -bottom-3 -right-6 h-px w-[calc(100%+3rem)] bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -bottom-6 -right-3 h-[calc(100%+3rem)] w-px bg-ink/30"></span>
          <img
            src="/images/bio-photo.png"
            alt="Portrait of León Palafox"
            class="aspect-[4/5] w-full object-cover mix-blend-multiply grayscale sepia-[.28] contrast-105"
            loading="eager"
          />
        </figure>

        <div class="max-w-lg space-y-0 text-[1.02rem] leading-relaxed">
          <p>
            I'm the <strong>Director of the AI Innovation Lab at <a class="text-signal-deep underline underline-offset-3 hover:text-signal" href="https://www.gbm.com/">GBM</a></strong>,
            where I lead large-scale personalization, recommender systems, embeddings, and experimentation
            platforms for retail investing.
          </p>
          <span aria-hidden="true" class="my-5 block h-[2px] w-10 bg-[#c0952f]"></span>
          <p>
            I'm also a lecturer at <a class="text-signal-deep underline underline-offset-3 hover:text-signal" href="https://www.up.edu.mx/en/mexico">Universidad Panamericana</a>,
            where I teach Deep Learning and Machine Learning, and I teach Deep Reinforcement Learning at Colegio
            de Matemáticas Bourbaki. I write a regular column in <em>El Financiero</em> on AI, data strategy, and
            innovation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-hairline px-6 py-14 sm:px-10 lg:px-14">
    <SectionHeading title="Research" id="research" />
    <div class="mt-8 max-w-2xl space-y-5 text-[1.05rem] leading-relaxed">
      <p>
        My research interest is applied machine learning, especially where data meets complex systems. I've worked
        across neuroscience, astrophysics, planetary sciences, and finance.
      </p>
      <p>
        Right now I'm exploring how machine learning can support decision-making in social and financial systems,
        from investment analytics to recommender systems for retail platforms.
      </p>
    </div>
  </section>

  <section class="border-b border-hairline px-6 py-14 sm:px-10 lg:px-14">
    <SectionHeading title="Academia" id="academia" />
    <div class="mt-8 max-w-2xl space-y-5 text-[1.05rem] leading-relaxed">
      <p>
        I earned my bachelor's degree in engineering from the National Autonomous University of Mexico (UNAM),
        graduating Magna Cum Laude and receiving the Medalla Gabino Barreda as the top student in my class. I earned
        my master's and PhD in machine learning applied to bioinformatics from the University of Tokyo, funded by
        the Monbukagakusho (MEXT) scholarship of the Japanese Ministry of Education.
      </p>
      <p>
        I later worked as a postdoctoral researcher at the UCLA School of Medicine, applying ML to neuroscience, and
        at the University of Arizona, applying ML to planetary sciences, where I then became a staff scientist.
      </p>
    </div>
  </section>

  <section class="border-b border-hairline px-6 py-14 sm:px-10 lg:px-14">
    <SectionHeading title="Industry" id="industry" />
    <div class="mt-8 max-w-2xl space-y-5 text-[1.05rem] leading-relaxed">
      <p>
        I've worked at the intersection of AI, data strategy, and business for over a decade. At GBM I direct the AI
        Innovation Lab: the "Genome" investor-profile projects, recommenders built on KNN, ALS, and BM25 with
        embeddings, and the <strong>Mechagodzilla</strong> experimentation layer that measures whether any of it
        actually works.
      </p>
      <p>
        Before GBM I directed the AI Innovation Lab at Novartis, headed AI at Algorithia (Grupo Salinas), and
        directed Machine Learning at Banorte Financial Group.
      </p>
    </div>
  </section>

  <section class="px-6 py-14 sm:px-10 lg:px-14">
    <SectionHeading title="Timeline" id="timeline" />
    <ul class="mt-8 max-w-3xl divide-y divide-hairline">
      {
        timeline.map((item) => (
          <li class="flex flex-col gap-1 py-4 sm:flex-row sm:items-baseline sm:gap-6">
            <span class="micro-label w-44 shrink-0 text-muted">
              {item.from} — {item.to}
            </span>
            <span class="flex-1 leading-snug">
              {item.role} <span class="text-muted">· {item.org}</span>
            </span>
            {item.current && <span aria-label="Current role" class="size-1.5 shrink-0 self-center rounded-full bg-signal" />}
          </li>
        ))
      }
    </ul>
  </section>
</Base>
