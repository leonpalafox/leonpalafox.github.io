---
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';

const logos = import.meta.glob<ImageMetadata>('../assets/logos/*.{png,jpg}', {
  eager: true,
  import: 'default',
});
const logo = (name: string) => logos[`../assets/logos/${name}`];

const timeline = [
  { from: '2025.07', to: 'Present', role: 'AI Innovation Lab Director', org: 'GBM', logo: logo('gbm.png'), current: true },
  { from: '2024.05', to: '2025.07', role: 'AI Innovation Lab Director', org: 'Novartis', logo: logo('novartis.png') },
  { from: '2022.10', to: '2024.05', role: 'AI Head', org: 'Algorithia (Grupo Salinas)', logo: logo('algorithia.png') },
  { from: '2021.07', to: '2022.10', role: 'Machine Learning Director', org: 'Banorte Financial Group', logo: logo('banorte.png') },
  { from: '2018.05', to: '2020.06', role: 'ML & Data Science Professor', org: 'Universidad Panamericana', logo: logo('up.png') },
  { from: '2017.03', to: '2018.05', role: 'Senior Data Science Consultant', org: 'Rich IT', logo: logo('richit.png') },
  { from: '2015.03', to: '2017.03', role: 'Staff Scientist', org: 'University of Arizona', logo: logo('arizona.png') },
  { from: '2014.04', to: '2015.03', role: 'Postdoctoral Fellow', org: 'University of Arizona', logo: logo('arizona.png') },
  { from: '2013.02', to: '2014.04', role: 'Postdoctoral Fellow', org: 'UCLA School of Medicine', logo: logo('ucla.jpg') },
  { from: '2012.08', to: '2012.09', role: 'Research Intern', org: 'National Institute of Informatics', logo: logo('nii.png') },
  { from: '2010.03', to: '2013.03', role: 'PhD, Machine Learning', org: 'The University of Tokyo', logo: logo('todai.png') },
  { from: '2008.04', to: '2010.03', role: "Master's, Information Technologies", org: 'The University of Tokyo', logo: logo('todai.png') },
  { from: '2007.04', to: '2013.03', role: 'Monbukagakusho (MEXT) Scholarship Fellow', org: 'Government of Japan', logo: logo('MEXT.png') },
  { from: '2006.02', to: '2007.02', role: 'Data & Business Analyst', org: 'San Luis Rassini', logo: logo('rassini.png') },
  { from: '2000.09', to: '2005.04', role: "Bachelor's, Engineering (Magna Cum Laude)", org: 'UNAM', logo: logo('unam.png') },
];
---

<Base
  title="About — León Palafox"
  description="Director of the AI Innovation Lab at GBM, PhD from the University of Tokyo, lecturer at Universidad Panamericana, and columnist at El Financiero."
>
  <!-- Collage hero: recreates assets/hero_anout.png as a live composition -->
  <section class="relative overflow-hidden border-b border-hairline bg-[#f4ebd7]">
    <!-- Collage panel (lg+): owns the right side, melts into the paper on its left edge -->
    <img
      src="/images/hero_1.png"
      alt=""
      aria-hidden="true"
      class="pointer-events-none absolute inset-y-0 right-0 hidden h-full w-[44%] object-cover object-right lg:block [mask-image:linear-gradient(to_left,#000_72%,transparent_100%)]"
      loading="eager"
    />

    <!-- Banner crop of the collage (below lg) -->
    <img
      src="/images/hero_1.png"
      alt="Paper collage of neural networks, market charts, books, and Mexico City architecture"
      class="h-56 w-full object-cover object-right sm:h-72 lg:hidden"
      loading="eager"
    />

    <!-- Drafting-sketch decorations -->
    <div aria-hidden="true" class="pointer-events-none absolute inset-0 hidden lg:block">
      <div
        class="absolute left-10 top-[46%] h-16 w-20 opacity-45"
        style="background-image: radial-gradient(var(--color-ink) 1px, transparent 1px); background-size: 9px 9px;"
      >
      </div>
      <div class="absolute -bottom-16 -left-12 size-44 rounded-full border border-ink/25"></div>
      <div class="absolute bottom-24 left-16 size-14 rounded-full border border-ink/20"></div>
      <svg class="absolute left-[52%] top-14 size-4 opacity-40" viewBox="0 0 16 16">
        <path d="M8 0 V16 M0 8 H16" stroke="var(--color-ink)" stroke-width="1"></path>
      </svg>
    </div>

    <div class="relative flex flex-col px-6 py-12 sm:px-10 lg:min-h-[520px] lg:w-[62%] lg:px-14 lg:py-14">
      <header data-reveal>
        <p class="micro-label flex items-center gap-3 text-signal">
          <span>About</span>
          <span lang="ja" class="text-muted tracking-[0.2em]">略歴</span>
        </p>
        <h1 class="mt-5 text-4xl font-semibold leading-[1.02] tracking-[-0.02em] sm:text-5xl">Hi, I'm León.</h1>
        <span aria-hidden="true" class="mt-6 block h-[3px] w-14 bg-signal"></span>
      </header>

      <div class="mt-12 flex flex-col gap-10 sm:flex-row sm:items-end lg:gap-12">
        <!-- Portrait in a drafting frame -->
        <figure data-reveal style="--reveal-delay: 130ms" class="relative w-44 shrink-0">
          <span aria-hidden="true" class="absolute -left-6 -top-3 h-px w-[calc(100%+3rem)] bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -top-6 -left-3 h-[calc(100%+3rem)] w-px bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -bottom-3 -right-6 h-px w-[calc(100%+3rem)] bg-ink/30"></span>
          <span aria-hidden="true" class="absolute -bottom-6 -right-3 h-[calc(100%+3rem)] w-px bg-ink/30"></span>
          <img
            src="/images/bio-photo.png"
            alt="Portrait of León Palafox"
            class="aspect-[4/5] w-full object-cover mix-blend-multiply grayscale sepia-[.28] contrast-105"
            loading="eager"
          />
        </figure>

        <div data-reveal style="--reveal-delay: 260ms" class="max-w-md space-y-0 text-[0.98rem] leading-[1.75]">
          <p>
            I'm the <strong>Director of the AI Innovation Lab at <a class="text-signal-deep underline underline-offset-3 hover:text-signal" href="https://www.gbm.com/">GBM</a></strong>,
            where I lead large-scale personalization, recommender systems, embeddings, and experimentation
            platforms for retail investing.
          </p>
          <span aria-hidden="true" class="my-5 block h-[2px] w-10 bg-[#c0952f]"></span>
          <p>
            I'm also a lecturer at <a class="text-signal-deep underline underline-offset-3 hover:text-signal" href="https://www.up.edu.mx/en/mexico">Universidad Panamericana</a>,
            where I teach Deep Learning and Machine Learning, and I teach Deep Reinforcement Learning at Colegio
            de Matemáticas Bourbaki. I write a regular column in <em>El Financiero</em> on AI, data strategy, and
            innovation.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="border-b border-hairline px-6 py-14 sm:px-10 lg:px-14">
    <div class="grid gap-6 lg:grid-cols-3">
      <article id="research" data-reveal class="border border-hairline bg-paper p-7">
        <p class="micro-label flex items-center gap-3 text-signal">
          <span>Research</span>
          <span lang="ja" class="text-muted tracking-[0.2em]">研究</span>
        </p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight">
          Where data meets complex systems
          <span aria-hidden="true" class="mt-2.5 block h-[3px] w-8 bg-signal"></span>
        </h2>
        <p class="mt-4 text-sm leading-relaxed">
          Applied machine learning across neuroscience, astrophysics, planetary sciences, and finance. Right now:
          how ML can support decision-making in social and financial systems, from investment analytics to
          recommenders for retail platforms.
        </p>
      </article>

      <article id="academia" data-reveal style="--reveal-delay: 90ms" class="border border-hairline bg-paper p-7">
        <p class="micro-label flex items-center gap-3 text-signal">
          <span>Academia</span>
          <span lang="ja" class="text-muted tracking-[0.2em]">学界</span>
        </p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight">
          UNAM → Tokyo → UCLA → Arizona
          <span aria-hidden="true" class="mt-2.5 block h-[3px] w-8 bg-signal"></span>
        </h2>
        <p class="mt-4 text-sm leading-relaxed">
          Engineering at UNAM — Magna Cum Laude, Medalla Gabino Barreda. Master's and PhD in ML for bioinformatics
          at the University of Tokyo on the Monbukagakusho (MEXT) scholarship. Postdocs applying ML to neuroscience
          (UCLA School of Medicine) and planetary sciences (University of Arizona), then staff scientist.
        </p>
      </article>

      <article id="industry" data-reveal style="--reveal-delay: 180ms" class="border border-hairline bg-paper p-7">
        <p class="micro-label flex items-center gap-3 text-signal">
          <span>Industry</span>
          <span lang="ja" class="text-muted tracking-[0.2em]">産業</span>
        </p>
        <h2 class="mt-3 text-xl font-semibold tracking-tight">
          A decade of AI that ships
          <span aria-hidden="true" class="mt-2.5 block h-[3px] w-8 bg-signal"></span>
        </h2>
        <p class="mt-4 text-sm leading-relaxed">
          At GBM: the "Genome" investor-profile projects, recommenders on KNN, ALS, and BM25 with embeddings, and
          the <strong>Mechagodzilla</strong> experimentation layer that measures whether any of it works. Before:
          AI Innovation Lab at Novartis, AI Head at Algorithia (Grupo Salinas), ML Director at Banorte.
        </p>
      </article>
    </div>
  </section>

  <section class="px-6 py-14 sm:px-10 lg:px-14">
    <SectionHeading title="Timeline" id="timeline" />
    <div class="relative mt-8 max-w-3xl">
      <ul class="divide-y divide-hairline">
        {
          timeline.map((item, i) => (
            <li
              data-reveal
              style={`--reveal-delay: ${Math.min(i * 45, 400)}ms`}
              class="group relative -mx-4 flex items-center gap-4 px-5 py-3.5 transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] sm:gap-6 hover:z-10 hover:-translate-y-1.5 hover:scale-[1.035] hover:bg-[#fbf8f1] hover:shadow-[0_22px_55px_rgba(20,20,18,0.20)]"
            >
              <span
                aria-hidden="true"
                class="absolute inset-y-2 left-0 w-[3px] origin-center scale-y-0 bg-signal transition-transform duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-y-100"
              />
              {item.logo ? (
                <Image
                  src={item.logo}
                  alt={`${item.org} logo`}
                  widths={[80, 160]}
                  sizes="40px"
                  class="size-10 shrink-0 object-contain opacity-75 mix-blend-multiply grayscale transition-all duration-300 ease-[cubic-bezier(0.22,1,0.36,1)] group-hover:scale-[1.45] group-hover:opacity-100 group-hover:grayscale-0"
                />
              ) : (
                <span class="size-10 shrink-0" />
              )}
              <span class="micro-label hidden w-44 shrink-0 text-muted transition-colors duration-300 sm:block group-hover:text-signal">
                {item.from} — {item.to}
              </span>
              <span class="flex-1 leading-snug">
                {item.role} <span class="text-muted">· {item.org}</span>
                <span class="micro-label mt-0.5 block text-muted sm:hidden">
                  {item.from} — {item.to}
                </span>
              </span>
              {item.current && <span aria-label="Current role" class="size-1.5 shrink-0 rounded-full bg-signal" />}
            </li>
          ))
        }
      </ul>
    </div>
  </section>
</Base>

<style is:global>
  @media (prefers-reduced-motion: no-preference) {
    body.reveal-armed [data-reveal] {
      opacity: 0;
      transform: translateY(26px);
      transition:
        opacity 0.7s ease,
        transform 0.7s cubic-bezier(0.22, 1, 0.36, 1);
      transition-delay: var(--reveal-delay, 0s);
    }
    body.reveal-armed [data-reveal].is-in {
      opacity: 1;
      transform: none;
    }
    /* Once revealed, hand transform control back to hover states */
    body.reveal-armed li[data-reveal].is-in {
      transition-delay: 0s;
      transition-property: all;
      transition-duration: 0.3s;
    }
  }
</style>

<script>
  const reveals = document.querySelectorAll('[data-reveal]');
  if ('IntersectionObserver' in window && !window.matchMedia('(prefers-reduced-motion: reduce)').matches) {
    document.body.classList.add('reveal-armed');
    const io = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add('is-in');
            io.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.12, rootMargin: '0px 0px -40px 0px' }
    );
    reveals.forEach((el) => io.observe(el));
  }
</script>
