---
import Base from '../layouts/Base.astro';
---

<Base title="Page not found — León Palafox">
  <section class="flex flex-col items-center px-6 py-28 text-center">
    <span aria-hidden="true" class="block size-24 rounded-full bg-signal"></span>
    <h1 class="mt-10 text-5xl font-semibold tracking-tight">404</h1>
    <p class="micro-label mt-4 text-muted">Page not found — <span lang="ja" class="tracking-[0.2em]">見つかりません</span></p>
    <a href="/" class="group micro-label mt-10 inline-flex items-center gap-2 text-signal-deep hover:text-signal">
      <span aria-hidden="true" class="transition-transform group-hover:-translate-x-1">←</span>
      Back home
    </a>
  </section>
</Base>
