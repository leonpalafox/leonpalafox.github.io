---

<Base
  title="Publications — León Palafox"
  description="Academic publications and industry writing by León Palafox on machine learning, Mars imagery, bioinformatics, financial AI, and data strategy."
>
  <PageHero
    eyebrow="Publications"
    jp="論文"
    title="Publications & research"
    description="From gene regulatory networks and Mars imagery to financial AI — the paper trail of fifteen years of applied machine learning."
  />

  {
    sections.map((section) => (
      <section class="border-b border-hairline px-6 py-14 last:border-b-0 sm:px-10 lg:px-14">
        <SectionHeading title={section.title} id={section.id} />
        {section.intro && <p class="mt-6 max-w-2xl leading-relaxed text-muted">{section.intro}</p>}
        <ul class="mt-8 max-w-3xl divide-y divide-hairline">
          {section.items.map((pub) => (
            <li class="flex gap-5 py-5">
              <span class="micro-label w-12 shrink-0 pt-1 text-signal-deep">{pub.year}</span>
              <div class="flex-1">
                {pub.href ? (
                  <a href={pub.href} class="group font-medium leading-snug hover:text-signal-deep">
                    {pub.title}
                    <span aria-hidden="true" class="ml-2 inline-block text-signal-deep transition-transform group-hover:translate-x-1">
                      →
                    </span>
                  </a>
                ) : (
                  <p class="font-medium leading-snug">{pub.title}</p>
                )}
                <p class="mt-1.5 text-sm text-muted">{pub.authors}</p>
                <p class="mt-0.5 font-serif text-sm italic text-muted">{pub.venue}</p>
              </div>
            </li>
          ))}
        </ul>
      </section>
    ))
  }
</Base>
