---
import { getCollection } from 'astro:content';
import { Image } from 'astro:assets';
import Base from '../layouts/Base.astro';
import SectionHeading from '../components/SectionHeading.astro';
import { kanjiYear } from '../lib/format';
import heroSun from '../assets/hero-sun.png';
import workPersonalization from '../assets/work-personalization.png';
import workMlops from '../assets/work-mlops.png';
import workRecsys from '../assets/work-recsys.png';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
  .slice(0, 3);

const focusAreas = [
  { label: 'Recommender systems', icon: 'grid' },
  { label: 'Embeddings', icon: 'overlap' },
  { label: 'MLOps', icon: 'layers' },
  { label: 'Experimentation', icon: 'chart' },
  { label: 'AI strategy', icon: 'target' },
] as const;

const selectedWork = [
  {
    title: 'Personalization at scale in financial services',
    href: '/about/#industry',
    thumb: workPersonalization,
  },
  {
    title: 'From models to impact: MLOps for reliable AI',
    href: '/about/#industry',
    thumb: workMlops,
  },
  {
    title: 'Building recommender systems people trust',
    href: '/publications/',
    thumb: workRecsys,
  },
];
---

<Base title="León Palafox — AI Strategy and Recommender Systems for Finance">
  <!-- Hero -->
  <section class="px-6 py-16 sm:px-10 lg:px-14 lg:py-24">
    <div class="grid items-center gap-14 lg:grid-cols-[1.05fr_0.95fr]">
      <div>
        <h1 class="text-[2.75rem] font-semibold leading-[1.02] tracking-[-0.035em] sm:text-6xl xl:text-[4rem] xl:leading-[0.98]">
          AI Strategy and Recommender Systems for&nbsp;Finance
        </h1>
        <p class="mt-7 text-lg text-muted">
          Director, AI Innovation Lab at GBM&ensp;·&ensp;Professor&ensp;·&ensp;Columnist
        </p>
        <a
          href="/about/"
          class="group mt-10 inline-flex items-center gap-3 bg-signal-deep px-7 py-4 text-[0.95rem] font-medium text-white transition-colors hover:brightness-90"
        >
          Explore my work
          <span aria-hidden="true" class="transition-transform group-hover:translate-x-1">→</span>
        </a>
      </div>

      <div class="relative mx-auto w-full max-w-xl">
        <Image
          src={heroSun}
          alt="A textured vermillion sun rising behind a black halftone wave, inside thin orbit rings"
          widths={[384, 576, 1152]}
          sizes="(min-width: 1024px) 576px, 90vw"
          loading="eager"
          class="h-auto w-full"
        />
        <div aria-hidden="true" class="absolute -right-14 top-1/2 hidden -translate-y-1/2 flex-col gap-10 2xl:flex">
          <p class="micro-label leading-5 text-muted">
            Signal<br />strength
            <span class="mt-1 block h-px w-4 bg-signal"></span>
            <span class="text-ink">Rising</span>
          </p>
          <p class="micro-label leading-5 text-muted">
            Data<br />intelligence<br />impact
            <span class="mt-1 block h-px w-4 bg-signal"></span>
          </p>
        </div>
      </div>
    </div>
  </section>

  <!-- Three-column band: focus / work / writing -->
  <section class="grid divide-y divide-hairline border-t border-hairline lg:grid-cols-3 lg:divide-x lg:divide-y-0">
    <div class="px-6 py-12 sm:px-10">
      <SectionHeading title="Focus areas" />
      <ul class="mt-8 space-y-3">
        {
          focusAreas.map((area) => (
            <li class="flex w-fit items-center gap-3 rounded-full border border-ink/25 py-2.5 pl-3.5 pr-5 text-[0.95rem]">
              <svg viewBox="0 0 20 20" aria-hidden="true" class="size-5 shrink-0">
                {area.icon === 'grid' &&
                  [4, 10, 16].flatMap((x) => [4, 10, 16].map((y) => <circle cx={x} cy={y} r="1.6" fill="var(--color-ink)" />))}
                {area.icon === 'overlap' && (
                  <>
                    <circle cx="7.5" cy="10" r="5" fill="none" stroke="var(--color-ink)" stroke-width="1.4" />
                    <circle cx="12.5" cy="10" r="5" fill="none" stroke="var(--color-ink)" stroke-width="1.4" />
                  </>
                )}
                {area.icon === 'layers' && (
                  <path
                    d="M10 3 L17 6.5 L10 10 L3 6.5 Z M4.8 9.8 L10 12.4 L15.2 9.8 M4.8 13 L10 15.6 L15.2 13"
                    fill="none"
                    stroke="var(--color-ink)"
                    stroke-width="1.3"
                    stroke-linejoin="round"
                  />
                )}
                {area.icon === 'chart' && (
                  <>
                    <path d="M3 15 L8 9 L11.5 12 L17 5" fill="none" stroke="var(--color-ink)" stroke-width="1.4" />
                    <circle cx="8" cy="9" r="1.5" fill="var(--color-ink)" />
                    <circle cx="17" cy="5" r="1.5" fill="var(--color-signal)" />
                  </>
                )}
                {area.icon === 'target' && (
                  <>
                    <circle cx="10" cy="10" r="6.5" fill="none" stroke="var(--color-ink)" stroke-width="1.3" />
                    <circle cx="10" cy="10" r="2" fill="var(--color-signal)" />
                    <path d="M10 1.5 V5 M10 15 V18.5 M1.5 10 H5 M15 10 H18.5" stroke="var(--color-ink)" stroke-width="1.3" />
                  </>
                )}
              </svg>
              {area.label}
            </li>
          ))
        }
      </ul>
    </div>

    <div class="px-6 py-12 sm:px-10">
      <SectionHeading title="Selected work" />
      <ul class="mt-4 divide-y divide-hairline">
        {
          selectedWork.map((work) => (
            <li>
              <a href={work.href} class="group flex items-center gap-5 py-5">
                <Image src={work.thumb} alt="" widths={[192]} sizes="96px" class="h-auto w-24 shrink-0" />
                <span class="flex-1 text-[0.95rem] leading-snug">{work.title}</span>
                <span aria-hidden="true" class="text-signal-deep transition-transform group-hover:translate-x-1">→</span>
              </a>
            </li>
          ))
        }
      </ul>
    </div>

    <div class="px-6 py-12 sm:px-10">
      <SectionHeading title="Latest writing" />
      <ul class="mt-4 divide-y divide-hairline">
        {
          posts.map((post) => (
            <li>
              <a href={`/blog/${post.id}/`} class="group flex items-center gap-5 py-5">
                <span class="flex shrink-0 flex-col items-center gap-2">
                  <span lang="ja" class="vertical-text text-[0.7rem] leading-none text-muted" title={post.data.pubDate.toISOString().slice(0, 10)}>
                    {kanjiYear(post.data.pubDate)}
                  </span>
                  <span aria-hidden="true" class="block size-1.5 rounded-full bg-signal" />
                </span>
                <span class="flex-1 text-[0.95rem] leading-snug" lang={post.data.lang}>
                  {post.data.title}
                </span>
                <span aria-hidden="true" class="text-signal-deep transition-transform group-hover:translate-x-1">→</span>
              </a>
            </li>
          ))
        }
      </ul>
      <a href="/blog/" class="micro-label mt-6 inline-flex items-center gap-2 text-signal-deep hover:text-signal">
        All posts <span aria-hidden="true">→</span>
      </a>
    </div>
  </section>
</Base>
